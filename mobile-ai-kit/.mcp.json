{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "figma-mcp": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "FIGMA-KEY",
        "FRAMELINK_TELEMETRY": "off",
        "DO_NOT_TRACK": "1"
      }
    },
    "notebooklm-mcp": {
      "command": "uvx",
      "args": ["--from", "notebooklm-mcp-cli", "notebooklm-mcp"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  }
}
